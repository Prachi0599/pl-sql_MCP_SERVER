DB_USER=MCP_APP
DB_PASSWORD=mcp123
DB_CONNECT_STRING=localhost:1521/FREEPDB1
OPENAI_API_KEY=your-openai-api-key-here
OPENAI_MODEL=gpt-4o-mini

# Optional: dedicated read-only account for the SQL read agent (sql_read_agent).
# Create it once with sql/create_readonly_user.sql (run as SYSTEM/DBA), then set
# these to match. When unset, the SQL agent falls back to the main DB_USER pool
# (statement validation still enforces SELECT-only).
DB_READONLY_USER=MCP_RO
DB_READONLY_PASSWORD=your-readonly-password-here
